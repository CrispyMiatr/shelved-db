{
    "compilerOptions": {
        "allowJs": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "isolatedModules": true,
        "target": "ESNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "ziggy-js": [
                "./vendor/tightenco/ziggy"
            ],
            "~/*": [
                "./resources/js/*"
            ],
            "~assets/*": [
                "./resources/assets/*"
            ],
            "~styles/*": [
                "./resources/css/*"
            ],
            "~types/*": [
                "./resources/types/*"
            ]
        }
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.tsx",
        "resources/js/**/*.d.ts",
        "resources/css/**/*.ts",
        "resources/assets/**/*.ts"
    ]
}